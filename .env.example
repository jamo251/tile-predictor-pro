# Never commit real secrets. Copy to `.env.local` for Vite-only vars, or set in Vercel dashboard.

# ── Vercel serverless (Project → Settings → Environment Variables)
# Required for image analysis. Server-only — not exposed to the browser.
GEMINI_API_KEY=

# Optional: split-origin SPA (comma-separated origins allowed to call POST /api)
# ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Optional distributed rate limiting (public portfolio abuse protection)
# https://upstash.com — when both are set, /api/analyze-board uses Redis sliding window limits.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Vite (prefixed vars are inlined into client — never put Gemini keys here)

# Rare: SPA hosted on another domain than the deployment that serves /api
# Example: https://tile-predictor.vercel.app
# VITE_API_ORIGIN=

# Optional analytics (browser SDK key; treat as non-secret)
# VITE_AMPLITUDE_API_KEY=

# Local dev only: alternate port for vercel dev (default proxies to http://127.0.0.1:3000)
# VITE_DEV_API_PROXY=http://127.0.0.1:3333
